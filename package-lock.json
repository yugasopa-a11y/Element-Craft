// AI-generated fallback combinations for unknown pairs
export function generateCombination(element1: string, element2: string): { name: string; description: string; emoji: string; category: string; rarity: string } | null {
  const key1 = `${element1}+${element2}`;
  const key2 = `${element2}+${element1}`;
  
  if (PREDEFINED_COMBINATIONS[key1]) {
    const name = PREDEFINED_COMBINATIONS[key1];
    const info = ELEMENT_DESCRIPTIONS[name];
    return { name, ...info };
  }
  if (PREDEFINED_COMBINATIONS[key2]) {
    const name = PREDEFINED_COMBINATIONS[key2];
    const info = ELEMENT_DESCRIPTIONS[name];
    return { name, ...info };
  }
  
  // AI generation for unknown combinations
  // These are logical fallbacks based on the elements
  const e1 = element1.toLowerCase();
  const e2 = element2.toLowerCase();
  
  // Check for impossible combinations
  const impossibleCombos = [
    ['water', 'water'],
    ['fire', 'fire'],
    ['earth', 'earth'],
    ['air', 'air'],
    ['unknown', 'unknown']
  ];
  
  for (const combo of impossibleCombos) {
    if ((e1 === combo[0] && e2 === combo[1]) || (e1 === combo[1] && e2 === combo[0])) {
      return null;
    }
  }
  
  // Generate logical combinations based on element categories
  const combinations = [
    {
      condition: (a: string, b: string) => a.includes('water') && b.includes('fire'),
      result: { name: 'Steam', description: 'Hot water vapor rising into the air.', emoji: '♨️', category: 'nature', rarity: 'common' }
    },
    {
      condition: (a: string, b: string) => a.includes('fire') && b.includes('earth'),
      result: { name: 'Lava', description: 'Molten rock flowing from a volcano.', emoji: '🌋', category: 'nature', rarity: 'uncommon' }
    },
    {
      condition: (a: string, b: string) => a.includes('water') && b.includes('earth'),
      result: { name: 'Mud', description: 'Wet earth, sticky and messy.', emoji: '🟤', category: 'nature', rarity: 'common' }
    },
    {
      condition: (a: string, b: string) => a.includes('air') && b.includes('water'),
      result: { name: 'Cloud', description: 'Fluffy white masses floating in the sky.', emoji: '☁️', category: 'nature', rarity: 'common' }
    },
    {
      condition: (a: string, b: string) => a.includes('air') && b.includes('fire'),
      result: { name: 'Energy', description: 'The power to make things happen.', emoji: '⚡', category: 'abstract', rarity: 'uncommon' }
    },
    {
      condition: (a: string, b: string) => a.includes('human') && b.includes('machine'),
      result: { name: 'Cyborg', description: 'A being with both organic and mechanical parts.', emoji: '🤖', category: 'technology', rarity: 'rare' }
    },
    {
      condition: (a: string, b: string) => a.includes('human') && b.includes('magic'),
      result: { name: 'Wizard', description: 'A person who practices magic.', emoji: '🧙', category: 'fantasy', rarity: 'rare' }
    },
    {
      condition: (a: string, b: string) => (a.includes('life') || b.includes('life')) && (a.includes('death') || b.includes('death')),
      result: { name: 'Reincarnation', description: 'The rebirth of a soul in a new body.', emoji: '🔄', category: 'abstract', rarity: 'legendary' }
    },
    {
      condition: (a: string, b: string) => a.includes('time') && b.includes('space'),
      result: { name: 'Universe', description: 'All of space and time.', emoji: '🌌', category: 'nature', rarity: 'legendary' }
    }
  ];
  
  for (const combo of combinations) {
    if (combo.condition(e1, e2)) {
      return combo.result;
    }
  }
  
  // Default fallback - return null to indicate no logical combination exists
  return null;
}